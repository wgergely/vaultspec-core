# =============================================================================
# vaultspec - Environment Variable Configuration
# =============================================================================
#
# Copy this file to .env.local and edit for your environment:
#
#   cp .env.example .env.local
#
# Required variables are uncommented; optional variables are commented out
# with their default values shown.
#
# Naming convention: VAULTSPEC_{CATEGORY}_{ITEM}
#
# =============================================================================


# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------

# Workspace root directory.  Most other paths are resolved relative to this.
# Type: Path | Default: current working directory
# VAULTSPEC_ROOT_DIR=.


# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------

# Agent sandboxing policy.  Controls file-system access.
# Options: read-write, read-only | Default: read-write
# VAULTSPEC_AGENT_MODE=read-write

# System prompt override injected into agent sessions.
# Type: String | Default: None (no override)
# VAULTSPEC_SYSTEM_PROMPT=

# Maximum number of LLM turns per agent session.
# Type: Integer (>= 1) | Default: None (unlimited)
# VAULTSPEC_MAX_TURNS=

# Maximum cost budget in USD for a single agent session.
# Type: Float (>= 0) | Default: None (unlimited)
# VAULTSPEC_BUDGET_USD=

# Comma-separated list of allowed MCP tools (whitelist).
# Type: CSV | Default: [] (all tools allowed)
# VAULTSPEC_ALLOWED_TOOLS=

# Comma-separated list of disallowed MCP tools (blacklist).
# Type: CSV | Default: [] (no tools blocked)
# VAULTSPEC_DISALLOWED_TOOLS=

# Agent effort level hint passed to the model.
# Options: high, medium, low | Default: None
# VAULTSPEC_EFFORT=

# Desired output format for agent responses.
# Options: json, text | Default: None
# VAULTSPEC_OUTPUT_FORMAT=

# Fallback model identifier if the primary model is unavailable.
# Type: String | Default: None
# VAULTSPEC_FALLBACK_MODEL=

# Comma-separated list of directories the agent may access.
# Type: CSV of paths | Default: [] (all directories)
# VAULTSPEC_INCLUDE_DIRS=


# -----------------------------------------------------------------------------
# MCP Server Configuration
# -----------------------------------------------------------------------------

# Workspace root for the MCP subagent server.
# Type: Path | REQUIRED when running the MCP server
# VAULTSPEC_MCP_ROOT_DIR=.

# MCP server listen port.
# Type: Integer (1024-65535) | Default: 10010
# VAULTSPEC_MCP_PORT=10010

# MCP server bind address.
# Type: String | Default: 0.0.0.0
# VAULTSPEC_MCP_HOST=0.0.0.0

# How long completed tasks are retained before automatic cleanup.
# Type: Float (seconds, >= 60) | Default: 3600.0 (1 hour)
# VAULTSPEC_MCP_TTL_SECONDS=3600.0


# -----------------------------------------------------------------------------
# A2A (Agent-to-Agent) Protocol
# -----------------------------------------------------------------------------

# Default port for A2A agent card URL generation.
# Type: Integer (1024-65535) | Default: 10010
# VAULTSPEC_A2A_DEFAULT_PORT=10010

# Host used in A2A agent discovery endpoints.
# Type: String | Default: localhost
# VAULTSPEC_A2A_HOST=localhost


# -----------------------------------------------------------------------------
# Storage Paths
# -----------------------------------------------------------------------------

# Vault documentation directory (relative to root).
# Type: Path | Default: .vault
# VAULTSPEC_DOCS_DIR=.vault

# Framework root directory (relative to root).
# Type: Path | Default: .vaultspec
# VAULTSPEC_FRAMEWORK_DIR=.vaultspec

# LanceDB vector database directory (relative to root).
# Type: Path | Default: .lance
# VAULTSPEC_LANCE_DIR=.lance

# Filename for incremental index metadata inside the lance directory.
# Type: String | Default: index_meta.json
# VAULTSPEC_INDEX_METADATA_FILE=index_meta.json


# -----------------------------------------------------------------------------
# Tool Directories
# -----------------------------------------------------------------------------

# Claude tool configuration directory (relative to root).
# Type: Path | Default: .claude
# VAULTSPEC_CLAUDE_DIR=.claude

# Gemini tool configuration directory (relative to root).
# Type: Path | Default: .gemini
# VAULTSPEC_GEMINI_DIR=.gemini

# Antigravity tool configuration directory (relative to root).
# Type: Path | Default: .antigravity
# VAULTSPEC_ANTIGRAVITY_DIR=.antigravity


# -----------------------------------------------------------------------------
# Orchestration
# -----------------------------------------------------------------------------

# Task engine cleanup TTL -- how long completed tasks live in memory.
# Type: Float (seconds, >= 60) | Default: 3600.0 (1 hour)
# VAULTSPEC_TASK_ENGINE_TTL_SECONDS=3600.0


# -----------------------------------------------------------------------------
# RAG / Embeddings
# -----------------------------------------------------------------------------

# VaultGraph in-memory cache TTL before the graph is rebuilt.
# Type: Float (seconds, >= 1) | Default: 300.0 (5 minutes)
# VAULTSPEC_GRAPH_TTL_SECONDS=300.0

# Number of documents per GPU embedding batch.
# Type: Integer (1-512) | Default: 64
# VAULTSPEC_EMBEDDING_BATCH_SIZE=64

# Maximum characters per document sent to the embedding model.
# Characters beyond this limit are truncated before encoding.
# Type: Integer (100-100000) | Default: 8000
# VAULTSPEC_MAX_EMBED_CHARS=8000

# Sentence-transformer model name for document embeddings.
# Type: String | Default: nomic-ai/nomic-embed-text-v1.5
# VAULTSPEC_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# Agent file polling interval for the MCP server (seconds).
# Type: Float (>= 0.5) | Default: 5.0
# VAULTSPEC_MCP_POLL_INTERVAL=5.0


# -----------------------------------------------------------------------------
# Editor
# -----------------------------------------------------------------------------

# Default editor command for creating rules, agents, skills.
# Falls back to legacy EDITOR env var.
# Type: String | Default: zed -w
# VAULTSPEC_EDITOR=zed -w


# -----------------------------------------------------------------------------
# I/O Configuration
# -----------------------------------------------------------------------------

# ACP subprocess stdout read buffer size in bytes.
# Type: Integer (256-1048576) | Default: 8192
# VAULTSPEC_IO_BUFFER_SIZE=8192

# Maximum terminal output captured from subprocesses in bytes.
# Type: Integer (10000-100000000) | Default: 1000000 (1 MB)
# VAULTSPEC_TERMINAL_OUTPUT_LIMIT=1000000


# -----------------------------------------------------------------------------
# Reference (read-only, informational — NOT config variables)
# -----------------------------------------------------------------------------
# These are not managed by CONFIG_REGISTRY. They exist as documentation only.
#
# Minimum Gemini CLI version required on Windows (ACP hang fix): 0.9.0
# Recommended Gemini CLI version for stable agent skills: 0.27.0
# Test lance suffixes are defined in .vaultspec/tests/constants.py
