# =============================================================================
# vaultspec-core environment variables
# =============================================================================
#
# Copy this file to `.env.local` and uncomment only the values you need.
# This file documents the live runtime config surface exposed by
# `vaultspec_core.config.CONFIG_REGISTRY`.
#
# Installed commands:
#   vaultspec-core
#   python -m vaultspec_core.mcp_server.app  (MCP server)
#
# =============================================================================


# -----------------------------------------------------------------------------
# Workspace
# -----------------------------------------------------------------------------

# Workspace root directory used by the CLI and MCP runtime.
# Type: Path | Default: current working directory
# VAULTSPEC_TARGET_DIR=.


# -----------------------------------------------------------------------------
# Vault Layout
# -----------------------------------------------------------------------------

# Vault document directory name relative to the workspace root.
# Type: String | Default: .vault
# VAULTSPEC_DOCS_DIR=.vault

# Framework resource directory name relative to the workspace root.
# Type: String | Default: .vaultspec
# VAULTSPEC_FRAMEWORK_DIR=.vaultspec


# -----------------------------------------------------------------------------
# Tool Directories
# -----------------------------------------------------------------------------

# Claude configuration directory name relative to the workspace root.
# Type: String | Default: .claude
# VAULTSPEC_CLAUDE_DIR=.claude

# Gemini configuration directory name relative to the workspace root.
# Type: String | Default: .gemini
# VAULTSPEC_GEMINI_DIR=.gemini

# Antigravity configuration directory name relative to the workspace root.
# Type: String | Default: .agents
# VAULTSPEC_ANTIGRAVITY_DIR=.agents


# -----------------------------------------------------------------------------
# Editor
# -----------------------------------------------------------------------------

# Default editor command used when creating or editing framework resources.
# Falls back to the legacy EDITOR environment variable when unset.
# Type: String | Default: zed -w
# VAULTSPEC_EDITOR=zed -w


# -----------------------------------------------------------------------------
# I/O
# -----------------------------------------------------------------------------

# Subprocess stdout read buffer size in bytes.
# Type: Integer (>= 1) | Default: 8192
# VAULTSPEC_IO_BUFFER_SIZE=8192

# Maximum terminal output captured from subprocesses in bytes.
# Type: Integer (>= 1) | Default: 1000000
# VAULTSPEC_TERMINAL_OUTPUT_LIMIT=1000000
